<!DOCTYPE html>
<html>
<head>
  <title>ProjectZeed Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="sidebar">
  <h2> ProjectZeed</h2>
  <a href="/dashboard">Dashboard</a>
  <a href="#">Restore</a>
  <a href="#">Analytics</a>
  <a href="#">Settings</a>
  <a href="/logout">Logout</a>
</div>

<div class="main">

  <h1>Welcome, <%= user.username %></h1>

  <div class="stats">
    <div class="stat-card">
      <h3>Total Servers</h3>
      <p><%= guilds.length %></p>
    </div>

    <div class="stat-card">
      <h3>Total Verified</h3>
      <p><%= totalVerified %></p>
    </div>
  </div>

  <div class="guild-grid">
    <% guilds.forEach(guild => { %>
      <div class="guild-card">
        <h3><%= guild.name %></h3>
        <p>ID: <%= guild.id %></p>
        <form method="POST" action="/dashboard/restore/<%= guild.id %>">
          <button>⚡ Restore Members</button>
          
        </form>
      </div>
    <% }) %>
  </div>

</div>

</body>
</html>